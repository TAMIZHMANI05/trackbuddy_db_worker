ENV=development

# Database
DATABASE_URL=postgres://trackbuddy:trackbuddy123@localhost:5432/trackbuddy?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Batching
BATCH_SIZE=50
FLUSH_INTERVAL_MS=2000

# TCP Settings
SOCKET_TIMEOUT_MS=300000
MAX_CONNECTIONS=10000

# Health HTTP endpoint
HEALTH_PORT=8081

# Logging
LOG_LEVEL=info

# Queue 
QUEUE_NAME=
